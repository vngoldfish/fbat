{
   "action": {
      "default_icon": {
         "128": "icon128.png",
         "48": "icon48.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [
      {
         "js": [ "content.js" ],
         "matches": [ "https://*.facebook.com/*", "https://*.fb.com/*" ],
         "run_at": "document_idle"
      },
      {
         "js": [ "fb_interceptor.js" ],
         "matches": [ "https://*.facebook.com/*", "https://*.fb.com/*" ],
         "run_at": "document_start",
         "world": "MAIN"
      },
      {
         "js": [ "fb_bridge.js" ],
         "matches": [ "https://*.facebook.com/*", "https://*.fb.com/*" ],
         "run_at": "document_start"
      }
   ],
   "default_locale": "en",
   "description": "Tự động đăng bài viết, video, thước phim (reels), bản tin (stories) trên Facebook",
   "host_permissions": [ "https://*.facebook.com/*", "https://*.fb.com/*", "http://localhost/*", "http://127.0.0.1/*" ],
   "icons": {
      "128": "icon128.png",
      "48": "icon48.png"
   },
   "manifest_version": 3,
   "name": "FB Auto Post & Schedule Helper",
   "options_ui": {
      "page": "options.html",
      "open_in_tab": false
   },
   "permissions": [ "alarms", "cookies", "tabs", "scripting", "storage", "webRequest" ],
   "version": "7.0.0",
   "web_accessible_resources": [ {
      "matches": [ "https://*.facebook.com/*", "https://*.fb.com/*" ],
      "resources": [ "page_script.js", "icon48.png", "popup.html", "popup.js", "dashboard.html", "dashboard.js" ]
   } ]
}
